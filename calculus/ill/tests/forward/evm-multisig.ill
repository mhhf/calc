#trace_symex (query: symex) I .

% ── Observation: benchmark exploration ───────────────────────────────────────

#benchmark_symex (query: symex) (iterations: 5) (mode: explore) I .

% ── Observation: profile persistent goals ────────────────────────────────────

#profile_symex_ffi (query: symex, useFFI: true, mode: explore) I .

