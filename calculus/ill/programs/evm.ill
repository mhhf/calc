% Abstract CALL — nondeterministic success/failure, memory preserved
evm/call:
  bytecode BC * pc PC * !arr_get BC PC 0xf1 * !inc PC PC' *
  gas GAS * !checked_sub GAS 0x2bc GAS' *
  stack [GAS_T, TO_T, VALUE_T, InOffset_T, InSize_T, OutOffset_T, OutSize_T | REST] *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    (stack [1 | REST] + stack [0 | REST])
  }.

% Abstract DELEGATECALL — 6 args (no value), same fork pattern
evm/delegatecall:
  bytecode BC * pc PC * !arr_get BC PC 0xf4 * !inc PC PC' *
  gas GAS * !checked_sub GAS 0x2bc GAS' *
  stack [GAS_T, TO_T, InOffset_T, InSize_T, OutOffset_T, OutSize_T | REST] *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    (stack [1 | REST] + stack [0 | REST])
  }.

% Abstract STATICCALL — 6 args (no value), same fork pattern
evm/staticcall:
  bytecode BC * pc PC * !arr_get BC PC 0xfa * !inc PC PC' *
  gas GAS * !checked_sub GAS 0x2bc GAS' *
  stack [GAS_T, TO_T, InOffset_T, InSize_T, OutOffset_T, OutSize_T | REST] *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    (stack [1 | REST] + stack [0 | REST])
  }.

evm/return:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xf3 *
  !inc PC PC' *
  gas GAS *
  stack [Offset, Size | REST] *
  memsize S *
  !mem_expand S Offset Size S' MemGas *
  !checked_sub GAS MemGas GAS'
  -o {
    bytecode BC *
    memsize S' *
    gas GAS' *
    stack REST *
    return
  }.

evm/invalid:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xfe
  -o {
    bytecode BC *
    invalid
  }.

evm/selfdestruct:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xff *
  gas GAS *
  !checked_sub GAS 0x1388 GAS' *
  stack [Addr | REST]
  -o {
    bytecode BC *
    stack REST *
    selfdestruct
  }.

evm/revert:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xfd
  -o {
    bytecode BC *
    revert
  }.
