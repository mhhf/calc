#import(bin.ill)

% EVM
%
% 00   STOP
% 01   ADD           *
% 02   MUL           *
% 03   SUB           *
% 04   DIV           *
% 06   MOD           *
% 0a   EXP           *

% 10   LT            *
% 11   GT            *
% 14   EQ
% 15   ISZERO        ?
% 16   AND           *
% 17   OR            *
% 19   NOT           *
% 1b   SHL           *
% 1c   SHR           *

% 20   SHA3          *

% 30   ADDRESS
% 31   BALANCE
% 33   CALLER
% 34   CALLVALUE     *
% 35   CALLDATALOAD  *
% 36   CALLDATASIZE  *
% 37   CALLDATACOPY  *

% 42   TIMESTAMP     *
% 45   GASLIMIT      *

% 51   MLOAD         *
% 52   MSTORE        *
% 53   MSTORE8       *
% 50   POP           *
% 54   SLOAD
% 59   MSIZE         *
% 55   SSTORE        *
% 56   JUMP          *
% 57   JUMPI
% 5a   GAS
% 5b   JUMPDEST
% 5f   PUSH0         *

% 60   PUSH1
% 61   PUSH2         *
% 63   PUSH4         *
% 73   PUSH20        *
% 7f   PUSH32        *

% 80   DUP1
% 81   DUP2          *
% 82   DUP3          *
% 83   DUP4          *
% 84   DUP5          *

% 90   SWAP1         *
% 91   SWAP2         *
% 92   SWAP3         *

% a4   LOG4          *

% f1   CALL          ?
% f3   RETURN        *
% fe   INVALID       *
% fd   REVERT        *

return: type.
invalid: type.
revert: type.
log0: type.
log1: bin -> type.
log2: bin -> bin -> type.
log3: bin -> bin -> bin -> type.
log4: bin -> bin -> bin -> bin -> type.
stop: type.
pc: bin -> type.
gas: bin -> type.
sh: nat -> type.
code: bin -> bin -> type.
stack: nat -> bin -> type.
storage: bin -> bin -> type.
sender: bin -> type.
address: bin -> type.
balance: bin -> bin -> type.
callvalue: bin -> type.
calldata: bin -> bin -> bin -> type.
calldatasize: bin -> type.
debug: bin -> type.
mem: bin -> type.
memsize: bin -> type.
mem_reading: bin -> bin -> bin -> type.
mem_read_done: bin -> type.
mem_base_found: bin -> bin -> type.
mem_patch: bin -> bin -> bin -> type.
mem_patch_byte: bin -> bin -> bin -> type.
write: bin -> bin -> bin -> bin.
write8: bin -> bin -> bin -> bin.
empty_mem: bin.
saved_mem: bin -> type.
saved_memsize: bin -> type.
calldatacopy_iter: bin -> bin -> bin -> bin -> type.
calldatacopy_done: bin -> type.
timestamp: bin -> type.
gaslimit: bin -> type.
shr: bin -> bin -> bin -> type.
shl: bin -> bin -> bin -> type.
concat: bin -> bin -> bin.
sha3: bin -> bin.
call: bin -> bin -> bin -> bin -> bin -> bin -> bin -> type.




%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  00

evm/stop:
  pc PC *
  code PC 0x00 *
  !inc PC PC'
  -o {
    code PC 0x00 *
    stop
  }.

evm/add:
  pc PC *
  code PC 0x01 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) A *
  stack SH  B
  -o {
    exists C. (
      code PC 0x01 *
      pc PC' *
      sh (s SH) *
      stack SH C *
      !plus A B C)
  }.

evm/mul:
  pc PC *
  code PC 0x02 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) A *
  stack SH  B
  -o {
    exists A'. exists B'. exists C. exists C'. (
      code PC 0x02 *
      pc PC' *
      sh (s SH) *
      stack SH C' *
      !trim A A' * !trim B B' * !mul A' B' C * !to256 C C')
  }.

evm/sub:
  pc PC *
  code PC 0x03 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) A *
  stack SH  B
  -o {
    exists C. (
      code PC 0x03 *
      pc PC' *
      sh (s SH) *
      stack SH C *
      !plus C B A)
  }.

evm/exp:
  pc PC *
  code PC 0x0a *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) Base *
  stack SH  Exponent
  -o {
    exists Base'. exists Exponent'. exists Result. exists Result'. (
      debug Base' *
      debug Exponent' *
      code PC 0x0a *
      pc PC' *
      sh (s SH) *
      stack SH Result' *
      !trim Base Base' * !trim Exponent Exponent' * !exp Base' Exponent' Result * !to256 Result Result')
  }.

evm/div:
  pc PC *
  code PC 0x04 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) A *
  stack SH  B
  -o {
    exists A'. exists B'. exists Q. exists Q'. (
      code PC 0x04 *
      pc PC' *
      sh (s SH) *
      stack SH Q' *
      !trim A A' * !trim B B' * !div A' B' Q * !to256 Q Q')
  }.

evm/mod:
  pc PC *
  code PC 0x06 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) A *
  stack SH  B
  -o {
    exists A'. exists B'. exists R. exists R'. (
      code PC 0x06 *
      pc PC' *
      sh (s SH) *
      stack SH R' *
      !trim A A' * !trim B B' * !mod A' B' R * !to256 R R')
  }.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  10

%evm/eq_eqeq:
%  code PC 0x14 *
%  pc PC *
%  !inc PC PC' *
%  gas GAS *
%  !plus 2 GAS GAS' * %10 = 2 *
%  sh SH'' *
%  !inc SH' SH'' *
%  !inc SH SH' *
%  stack SH' X *
%  stack SH X
%  -o {
%    pc PC' *
%    gas GAS' *
%    code PC 0x14 *
%    sh SH' *
%    stack SH 1
%  }.

evm/eq:
  pc PC *
  code PC 0x14 *
  !inc PC PC' *
  gas GAS *
  !plus 2 GAS GAS' * %10 = 2 *
  sh (s (s SH)) *
  stack (s SH) X *
  stack SH Y
  -o {
    pc PC' *
    gas GAS' *
    code PC 0x14 *
    sh (s SH) *
    ((!neq X Y -o {
      stack SH 0
    }) +
    (!eq X Y -o {
      stack SH 1
    }))
  }.

evm/iszero:
  pc PC *
  code PC 0x15 *
  !inc PC PC' *
  gas GAS *
  !inc GAS GAS' *
  sh (s SH) *
  stack SH V
  -o {
    code PC 0x15 *
    pc PC' *
    gas GAS' *
    sh (s SH) *
    ((!eq V 0 -o { stack SH 1 }) +
     (!neq V 0 -o { stack SH 0 }))
  }.

evm/lt:
  pc PC *
  code PC 0x10 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) X *
  stack SH Y
  -o {
    exists Z. exists Z'. (
      code PC 0x10 *
      pc PC' *
      sh (s SH) *
      stack SH Z' *
      !gt Y X 0 Z * !to256 Z Z')
  }.

evm/gt:
  pc PC *
  code PC 0x11 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) X *
  stack SH Y
  -o {
    exists Z. exists Z'. (
      code PC 0x11 *
      pc PC' *
      sh (s SH) *
      stack SH Z' *
      !gt X Y 0 Z * !to256 Z Z')
  }.

evm/and:
  pc PC *
  code PC 0x16 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) X *
  stack SH  Y
  -o {
    exists Z. (
      code PC 0x16 *
      pc PC' *
      sh (s SH) *
      stack SH Z *
      !and X Y Z)
  }.

evm/or:
  pc PC *
  code PC 0x17 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) X *
  stack SH  Y
  -o {
    exists Z. (
      code PC 0x17 *
      pc PC' *
      sh (s SH) *
      stack SH Z *
      !or X Y Z)
  }.

evm/not:
  pc PC *
  code PC 0x19 *
  !inc PC PC' *
  sh (s SH) *
  stack SH X
  -o {
    exists Y. (
      code PC 0x19 *
      pc PC' *
      sh (s SH) *
      stack SH Y *
      !not X Y)
  }.

evm/shl:
  pc PC *
  code PC 0x1b *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) Shift *
  stack SH  Value
  -o {
    exists Z. (
      code PC 0x1b *
      pc PC' *
      sh (s SH) *
      stack SH Z *
      !shl Shift Value Z)
  }.

evm/shr:
  pc PC *
  code PC 0x1c *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) Shift *
  stack SH  Value
  -o {
    exists Z. (
      code PC 0x1c *
      pc PC' *
      sh (s SH) *
      stack SH Z *
      !shr Shift Value Z)
  }.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  20

evm/sha3:
  pc PC *
  code PC 0x20 *
  !inc PC PC' *
  gas GAS *
  !inc GAS GAS' *
  sh (s (s SH)) *
  stack (s SH) Offset *
  stack SH Size *
  mem M * memsize S *
  !mem_expand S Offset Size S' *
  !mem_read_range M Offset Size Bytes
  -o {
    code PC 0x20 *
    pc PC' *
    gas GAS' *
    sh (s SH) *
    stack SH (sha3 Bytes) *
    mem M * memsize S'
  }.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  30

evm/address:
  pc PC *
  code PC 0x30 *
  !inc PC PC' *
  gas GAS *
  !plus 2 GAS GAS' * %10 = 2 *
  sh SH *
  address A
  -o {
    pc PC' *
    gas GAS' *
    code PC 0x30 *
    sh (s SH) *
    address A *
    stack SH A
  }.

evm/balance:
  pc PC *
  code PC 0x31 *
  !inc PC PC' *
  gas GAS *
  !plus 512 GAS GAS' *
  sh (s SH) *
  stack SH A *
  balance A B
  -o {
    code PC 0x31 *
    pc PC' *
    gas GAS' *
    sh (s SH) *
    stack SH B *
    balance A B
  }.

evm/caller:
  pc PC *
  code PC 0x33 *
  !inc PC PC' *
  gas GAS *
  !plus 2 GAS GAS' * %10 = 2 *
  sh SH *
  sender SENDER
  -o {
    pc PC' *
    gas GAS' *
    code PC 0x33 *
    sh (s SH) *
    sender SENDER *
    stack SH SENDER
  }.

evm/callvalue:
  code PC 0x34 *
  pc PC *
  !inc PC PC' *
  gas GAS *
  !plus 2 GAS GAS' * %10 = 2 *
  sh SH *
  callvalue Value
  -o {
    pc PC' *
    gas GAS' *
    code PC 0x34 *
    sh (s SH) *
    callvalue Value *
    stack SH Value
  }.

