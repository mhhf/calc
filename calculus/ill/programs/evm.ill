% Abstract CALL — nondeterministic success/failure, memory preserved
evm/call:
  bytecode BC * pc PC * !arr_get BC PC 0xf1 * !inc PC PC' *
  gas GAS * !inc GAS GAS' *
  sh (s (s (s (s (s (s (s SH))))))) *
  stack (s (s (s (s (s (s SH)))))) GAS_T *
  stack (s (s (s (s (s SH))))) TO_T *
  stack (s (s (s (s SH)))) VALUE_T *
  stack (s (s (s SH))) InOffset_T *
  stack (s (s SH)) InSize_T *
  stack (s SH) OutOffset_T *
  stack SH OutSize_T *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    sh (s SH) *
    (stack SH 1 + stack SH 0)
  }.

% Abstract DELEGATECALL — 6 args (no value), same fork pattern
evm/delegatecall:
  bytecode BC * pc PC * !arr_get BC PC 0xf4 * !inc PC PC' *
  gas GAS * !inc GAS GAS' *
  sh (s (s (s (s (s (s SH)))))) *
  stack (s (s (s (s (s SH))))) GAS_T *
  stack (s (s (s (s SH)))) TO_T *
  stack (s (s (s SH))) InOffset_T *
  stack (s (s SH)) InSize_T *
  stack (s SH) OutOffset_T *
  stack SH OutSize_T *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    sh (s SH) *
    (stack SH 1 + stack SH 0)
  }.

% Abstract STATICCALL — 6 args (no value), same fork pattern
evm/staticcall:
  bytecode BC * pc PC * !arr_get BC PC 0xfa * !inc PC PC' *
  gas GAS * !inc GAS GAS' *
  sh (s (s (s (s (s (s SH)))))) *
  stack (s (s (s (s (s SH))))) GAS_T *
  stack (s (s (s (s SH)))) TO_T *
  stack (s (s (s SH))) InOffset_T *
  stack (s (s SH)) InSize_T *
  stack (s SH) OutOffset_T *
  stack SH OutSize_T *
  mem M * memsize S
  -o {
    bytecode BC * pc PC' * gas GAS' *
    mem M * memsize S *
    sh (s SH) *
    (stack SH 1 + stack SH 0)
  }.

evm/return:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xf3 *
  !inc PC PC' *
  sh (s (s SH)) *
  stack (s SH) Offset *
  stack SH  Size
  -o {
    bytecode BC *
    sh SH *
    return
  }.

evm/invalid:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xfe
  -o {
    bytecode BC *
    invalid
  }.

evm/revert:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0xfd
  -o {
    bytecode BC *
    revert
  }.
