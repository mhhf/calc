evm/dup1:
  bytecode BC *
  pc PC *
  !arr_get BC PC 0x80 *
  !inc PC PC' *
  gas GAS *
  !plus 3 GAS GAS' * %11 = 3
  sh (s SH) *
  stack SH V
  -o {
    bytecode BC *
    pc PC' *
    gas GAS' *
    sh (s (s SH)) *
    stack SH V *
    stack (s SH) V
  }.

evm/dup2:
  bytecode BC *
  pc PC *
