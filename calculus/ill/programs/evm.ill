evm/push2:
  pc PC *
  code PC 0x61 *
  !inc PC PC' *
  code PC' V *
  !plus 2 PC' PC_Target *
  gas GAS *
  !plus 3 GAS GAS' *
  sh SH
  -o {
    code PC 0x61 *
    pc PC_Target *
    sh (s SH) *
    stack SH V *
    gas GAS'
  }.

evm/push4:
  pc PC *
  code PC 0x63 *
  !inc PC PC' *
  code PC' V *
  !plus 4 PC' PC_Target *
  gas GAS *
  !plus 3 GAS GAS' *
  sh SH
  -o {
    code PC 0x63 *
    pc PC_Target *
    sh (s SH) *
    stack SH V *
    gas GAS'
  }.

evm/push20:
  pc PC *
  code PC 0x73 *
  !inc PC PC' *
  code PC' V *
  !plus 20 PC' PC_Target *
  gas GAS *
  !plus 3 GAS GAS' *
  sh SH
  -o {
    code PC 0x73 *
    pc PC_Target *
    sh (s SH) *
    stack SH V *
    gas GAS'
  }.

evm/push32:
  pc PC *
  code PC 0x7f *
  !inc PC PC' *
  code PC' V *
  !plus 32 PC' PC_Target *
  gas GAS *
  !plus 3 GAS GAS' *
  sh SH
  -o {
    code PC 0x7f *
    pc PC_Target *
    sh (s SH) *
    stack SH V *
    gas GAS'
  }.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  70

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%  80

evm/dup1:
  pc PC *
  code PC 0x80 *
  !inc PC PC' *
  gas GAS *
  !plus 3 GAS GAS' * %11 = 3
  sh (s SH) *
  stack SH V
  -o {
    code PC 0x80 *
    pc PC' *
    gas GAS' *
    sh (s (s SH)) *
    stack SH V *
    stack (s SH) V
  }.

evm/dup2:
  pc PC *
  code PC 0x81 *
  !inc PC PC' *
  gas GAS *
  !plus 3 GAS GAS' * %11 = 3
  sh (s (s SH)) *
  stack SH V
  -o {
    code PC 0x81 *
    pc PC' *
    gas GAS' *
    sh (s (s (s SH))) *
    stack SH V *
    stack (s (s SH)) V
  }.

