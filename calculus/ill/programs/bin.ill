%  <- concat Z X Y.


%reverse: bin -> bin -> type.
%reverse/z: reverse e e.
%reverse/s1: reverse (i X)

% to256: truncate to 256 bits (mod 2^256) via AND with max_uint256.
to256/z: to256 X Y
  <- and X 0xffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff Y.


reverse: bin -> bin -> type.
reverse_h: bin -> bin -> bin -> type.

reverse/z: reverse X Y
  <- reverse_h X e Y.


reverse_h/z: reverse_h e Y Y.
reverse_h/si: reverse_h (i X) Y Z
  <- reverse_h X (i Y) Z.
reverse_h/so: reverse_h (o X) Y Z
  <- reverse_h X (o Y) Z.

trim: bin -> bin -> type.

%       curr   trim   orig   res
trim_h: bin -> bin -> bin -> bin -> type.

trim_h/z: trim_h e X Y Z
  <- reverse X Z.

trim_h/si: trim_h (i N) X Y Z
  <- trim_h N (i Y) (i Y) Z.

trim_h/so: trim_h (o N) X Y Z
  <- trim_h N X (o Y) Z.

trim/z: trim X Y
  <- trim_h X e e Y.



